{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spaceleoch.github.io/ai-signal-brief/schemas/report.schema.json",
  "title": "AI Signal Brief Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "report_id",
    "report_date",
    "generated_at",
    "timezone",
    "language",
    "title",
    "summary",
    "stories",
    "sources",
    "assets",
    "provenance"
  ],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "report_id": { "type": "string", "minLength": 1 },
    "report_date": { "type": "string", "format": "date" },
    "generated_at": { "type": "string", "format": "date-time" },
    "timezone": { "type": "string", "minLength": 1 },
    "language": { "type": "string", "minLength": 2 },
    "title": { "type": "string", "minLength": 1 },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["top_stories"],
      "properties": {
        "top_stories": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["story_id", "rank", "headline", "why_it_matters"],
            "properties": {
              "story_id": { "type": "string" },
              "rank": { "type": "integer", "minimum": 1 },
              "headline": { "type": "string" },
              "why_it_matters": { "type": "string" }
            }
          }
        }
      }
    },
    "stories": {
      "type": "array",
      "items": { "$ref": "#/$defs/story" }
    },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/source" }
    },
    "assets": {
      "type": "array",
      "items": { "$ref": "#/$defs/asset" }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "story": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "rank",
        "title",
        "status",
        "importance",
        "companies",
        "models",
        "regions",
        "claims",
        "source_ids",
        "analysis"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "rank": { "type": "integer", "minimum": 1 },
        "title": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["new", "update", "follow_up", "correction"] },
        "importance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["score", "rationale"],
          "properties": {
            "score": { "type": "integer", "minimum": 1, "maximum": 5 },
            "rationale": { "type": "string", "minLength": 1 }
          }
        },
        "companies": { "type": "array", "items": { "type": "string" } },
        "models": { "type": "array", "items": { "type": "string" } },
        "regions": { "type": "array", "items": { "type": "string" } },
        "claims": { "type": "array", "items": { "$ref": "#/$defs/claim" } },
        "source_ids": { "type": "array", "items": { "type": "string" } },
        "analysis": { "type": "string" }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text", "source_ids", "verification_status", "confidence"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "text": { "type": "string", "minLength": 1 },
        "source_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "verification_status": { "type": "string", "enum": ["supported", "partially_supported", "unverified"] },
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "publisher", "url", "source_type", "published_at", "retrieved_at"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "publisher": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "source_type": { "type": "string", "enum": ["official", "paper", "repository", "regulatory", "news", "social", "other"] },
        "published_at": { "type": "string", "format": "date-time" },
        "retrieved_at": { "type": "string", "format": "date-time" }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "path", "license"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "path": { "type": "string" },
        "license": { "type": "string" }
      }
    }
  }
}