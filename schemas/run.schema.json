{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leombe.github.io/ai-signal-brief/schemas/run.schema.json",
  "title": "AI Signal Brief Run Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "started_at",
    "timezone",
    "status",
    "mode",
    "environment",
    "report_id",
    "report_date",
    "artifacts",
    "delivery",
    "warnings",
    "errors"
  ],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "run_id": { "type": "string", "minLength": 1 },
    "started_at": { "type": "string", "format": "date-time" },
    "ended_at": { "type": ["string", "null"], "format": "date-time" },
    "timezone": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["success", "partial", "failed", "dry_run"] },
    "mode": { "type": "string", "enum": ["manual", "scheduled", "test"] },
    "environment": { "type": "string", "enum": ["local", "github_actions", "other"] },
    "report_id": { "type": "string", "minLength": 1 },
    "report_date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "path"],
        "properties": {
          "kind": { "type": "string" },
          "path": { "type": "string" },
          "sha256": { "type": "string" }
        }
      }
    },
    "delivery": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "telegram": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "status": { "type": "string" }
          }
        }
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
